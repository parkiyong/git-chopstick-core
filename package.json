{
  "name": "git-chopstick-core",
  "version": "0.1.2",
  
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "import": "./src/*",
      "types": "./src/*"
    }
  },
  "files": ["dist", "src"],
  "description": "Git backend library extracted from GitHub Desktop",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "byline": "^5.0.0",
    "ignore": "^7.0.5",
    "memoize-one": "^6.0.0"
  },
  "devDependencies": {
    "@types/byline": "^4.2.36",
    "@types/node": "^22.19.20",
    "typescript": "^5.9.3"
  }
}
